# ----------------------------------------------------------------------------
# Aura Manufacturers — frontend environment variables
# Copy this file to .env.local for local dev. On Vercel, set the same keys
# in Project Settings → Environment Variables (Production + Preview scopes).
# ----------------------------------------------------------------------------

# Supabase (browser-safe; both keys are public-by-design)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# .NET backend API base URL.
# Local dev:        http://localhost:5000
# Production:       the public URL of your deployed .NET API (Render, Railway,
#                   Fly.io, Azure App Service, etc.)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Public site URL — used for canonicals, sitemap, OG/Twitter cards, JSON-LD.
# Local dev:        http://localhost:3000
# Production:       https://your-real-domain.com (NO trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp business number used in CTAs (no leading +)
NEXT_PUBLIC_WHATSAPP_NUMBER=923258828885

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
# Loaded only in production builds; leave blank locally to disable.
NEXT_PUBLIC_GA_ID=
